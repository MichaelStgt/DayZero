<?xml version="1.0" encoding="UTF-8" ?>
<Application
    x:Class="DayZero.App"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:DayZero">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary x:Name="Colors" Source="Resources/Styles/ApplicationColors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Converter.xaml" />
                <ResourceDictionary x:Name="Styles" Source="Resources/Styles/Styles.xaml" />
                <ResourceDictionary x:Name="FontIcons" Source="Resources/Styles/FontIcons.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
