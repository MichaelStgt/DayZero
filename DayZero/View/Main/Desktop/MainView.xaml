<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="DayZero.View.Desktop.MainView"
    xmlns="http://schemas.microsoft.com/dotnet/maui/global"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:DataType="MainViewModel">
    <Grid
        ColumnDefinitions="1*"
        RowDefinitions="Auto, 1*">
        <PagePlatformHeader
            Margin="{x:StaticResource DefaultElementMargin}"
            FontSize="{x:StaticResource SmallFontSize}"
            InfoName="Page:"
            IsVisible="{x:DynamicResource DisplayPageHeader}"
            SymbolFontSize="20"
            TextColor="{x:AppThemeBinding Light={x:StaticResource OffBlack},
                                          Dark={x:StaticResource OffWhite}}"
            Value="Desktop.MainView" />
        <VerticalStackLayout
            Grid.Row="1"
            HorizontalOptions="Center"
            Spacing="25"
            VerticalOptions="Center">

            <Label
                SemanticProperties.HeadingLevel="Level1"
                Style="{x:StaticResource Headline}"
                Text="Hello, World!" />

            <Label
                SemanticProperties.Description="Welcome to dot net Multi platform App UI"
                SemanticProperties.HeadingLevel="Level2"
                Style="{x:StaticResource SubHeadline}"
                Text="Welcome to &#10;.NET Multi-platform App UI" />

            <Button
                x:Name="CounterBtn"
                Command="{x:Binding CountUpCommand}"
                HorizontalOptions="Fill"
                SemanticProperties.Hint="Counts the number of times you click"
                Text="{x:Binding Text}" />
            <Label
                x:Name="MessagingLabel"
                Margin="30,8"
                Text="{x:Binding Text}" />
        </VerticalStackLayout>
    </Grid>


</ContentPage>
